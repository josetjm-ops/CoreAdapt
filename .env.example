# CoreAdapt API Configuration — v2.0
# ─────────────────────────────────────────────────────────────────────────────
# ESTRATEGIA MULTI-LLM (Failover automático: DeepSeek → Claude → OpenAI)
# Al menos una clave LLM es requerida. Se recomienda configurar las tres.
# ─────────────────────────────────────────────────────────────────────────────

# PROVEEDOR 1 — DeepSeek (Principal)
DEEPSEEK_API_KEY=your_deepseek_api_key

# PROVEEDOR 2 — Anthropic Claude (Fallback #1)
ANTHROPIC_API_KEY=your_anthropic_api_key

# PROVEEDOR 3 — OpenAI GPT-4o-mini (Fallback #2)
OPENAI_API_KEY=your_openai_api_key

# ─────────────────────────────────────────────────────────────────────────────
# FIREBASE CLIENT (frontend — variables públicas VITE_*)
# ─────────────────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─────────────────────────────────────────────────────────────────────────────
# FIREBASE ADMIN SDK (serverless functions — nunca exponer al cliente)
# Obtener desde: Firebase Console → Project Settings → Service Accounts
# El valor es el JSON completo del Service Account en una sola línea
# ─────────────────────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"..."}

# ─────────────────────────────────────────────────────────────────────────────
# STRAVA INTEGRATION
# ─────────────────────────────────────────────────────────────────────────────
VITE_STRAVA_CLIENT_ID=your_strava_client_id
VITE_STRAVA_CLIENT_SECRET=your_strava_client_secret
VITE_STRAVA_REDIRECT_URI=https://your-app.vercel.app/callback

# Server-side Strava (serverless functions)
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret

# Webhook security
# STRAVA_WEBHOOK_VERIFY_TOKEN — token para handshake inicial con Strava
STRAVA_WEBHOOK_VERIFY_TOKEN=coreadapt_webhook_2026

# STRAVA_WEBHOOK_SECRET — clave para validación HMAC-SHA256 de payloads
# Generar con: openssl rand -hex 32
STRAVA_WEBHOOK_SECRET=your_hmac_webhook_secret_hex

# ─────────────────────────────────────────────────────────────────────────────
# GARMIN CONNECT (OAuth 2.0 + PKCE — configurado, activación pendiente)
# ─────────────────────────────────────────────────────────────────────────────
VITE_GARMIN_CLIENT_ID=your_garmin_client_id
VITE_GARMIN_REDIRECT_URI=https://your-app.vercel.app/callback

# ─────────────────────────────────────────────────────────────────────────────
# SEGURIDAD INTERNA
# ─────────────────────────────────────────────────────────────────────────────
# SYNC_SECRET — protege el endpoint /api/sync-knowledge
SYNC_SECRET=your_sync_secret_here

# VITE_BRAIN_API_KEY — compatibilidad legada (puede eliminarse si no se usa)
VITE_BRAIN_API_KEY=your_llm_api_key
